#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DEFAULT_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
ROOT="${HARNESS_ROOT:-$DEFAULT_ROOT}"
dry_run=0

args=()
while (($# > 0)); do
  case "$1" in
    --dry-run)
      dry_run=1
      shift
      ;;
    --contract)
      shift
      ;;
    *)
      args+=("$1")
      shift
      ;;
  esac
done

HARNESS_ROOT="$ROOT" \
  "$ROOT/.harness/bin/resolve-feature.sh" --client claude --contract

if ((dry_run)); then
  exit 0
fi

cd "$ROOT"
exec claude "${args[@]}"
