#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DEFAULT_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
ROOT="${HARNESS_ROOT:-$DEFAULT_ROOT}"
dry_run=0
contract_only=0

args=()
while (($# > 0)); do
  case "$1" in
    --dry-run)
      dry_run=1
      shift
      ;;
    --contract)
      contract_only=1
      shift
      ;;
    *)
      args+=("$1")
      shift
      ;;
  esac
done

contract="$(HARNESS_ROOT="$ROOT" \
  "$ROOT/.harness/bin/resolve-feature.sh" --client codex --contract)"
if [[ -d "$ROOT/.repo" ]]; then
  branch_output=''
  if ! branch_output="$(HARNESS_ROOT="$ROOT" \
    "$ROOT/.harness/bin/check-branches.sh")"; then
    printf '%s\n' "$branch_output" >&2
    exit 1
  fi
  if ((contract_only == 0)); then
    printf '%s\n' "$branch_output"
  fi
fi
printf '%s\n' "$contract"

if ((dry_run)); then
  exit 0
fi

cd "$ROOT"
exec codex "${args[@]}"
